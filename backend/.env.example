# Database Configuration
# SQLite database connection URL with aiosqlite driver
DATABASE_URL=sqlite+aiosqlite:///./data/todowka.db

# Security Configuration
# Secret key for JWT token signing - generate a random 64-character string for production
SECRET_KEY=changeme-generate-random-string-64-characters

# JWT Token Expiration
# Access token lifetime in minutes (recommended: 15 for production)
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Refresh token lifetime in days (recommended: 7 for production)
REFRESH_TOKEN_EXPIRE_DAYS=7

# Refresh Token Rotation
# When enabled, old refresh tokens are revoked after being used once
# Recommended: true for production security
REFRESH_TOKEN_ROTATION_ENABLED=true

# User Registration
# Set to false to disable public registration (use INVITE_CODE instead)
REGISTRATION_ENABLED=true

# Optional: Maximum number of users allowed in the system
# Set to null or remove to allow unlimited users
# MAX_USERS=10

# Optional: Require invite code for registration when REGISTRATION_ENABLED=false
# INVITE_CODE=your-secret-invite-code

# CORS Configuration
# Comma-separated list of allowed origins for cross-origin requests
# Include both development and production URLs
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:80,https://yourdomain.com

# Application Environment
# Set to 'development' for debug mode, 'production' for optimized performance
APP_ENV=development

# Logging Level
# Options: debug, info, warning, error, critical
LOG_LEVEL=info

# Rate Limiting
# Maximum login attempts per minute per IP address
LOGIN_RATE_LIMIT=5

# Maximum registration attempts per hour per IP address
REGISTER_RATE_LIMIT=3

# Password Security
# bcrypt cost factor (higher = more secure but slower). Recommended: 12
BCRYPT_ROUNDS=12

# Check passwords against HaveIBeenPwned breach database (requires internet)
# Uses k-anonymity: only first 5 chars of SHA-1 hash are sent
HIBP_ENABLED=false

# API Rate Limits
# Limits for write operations (POST, PUT, PATCH, DELETE)
RATE_LIMIT_WRITE=20/minute

# Limits for read operations (GET)
RATE_LIMIT_READ=60/minute

# Limits for SSE connections
RATE_LIMIT_SSE=5/minute

# Limits for export operations
RATE_LIMIT_EXPORT=5/minute

# SMTP Configuration for email notifications
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASSWORD=your-password
# SMTP_FROM=Todowka <your-email@example.com>
