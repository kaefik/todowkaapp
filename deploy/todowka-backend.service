[Unit]
Description=Todowka Backend API
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/var/www/todowkaapp/backend
ExecStart=/var/www/todowkaapp/backend/venv/bin/python -m uvicorn app.main:app --host 127.0.0.1 --port 8000 --workers 2
Restart=always
RestartSec=5
EnvironmentFile=/var/www/todowkaapp/backend/.env

[Install]
WantedBy=multi-user.target
